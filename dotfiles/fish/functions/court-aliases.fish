# Abbreviations expand on space, so `co<space>` becomes `court-onboard`.
# Add or remove freely; this file is owned by court-onboard but only
# rewritten when missing.

abbr -a co       court-onboard
abbr -a cu       court-up
abbr -a cdown    court-down
abbr -a cg       court-grant
abbr -a ck       court-keygen
abbr -a capprove court-approve
abbr -a cs       court-send
abbr -a cinvite  court-invite-export
