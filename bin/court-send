#!/usr/bin/env bash
# agent-court — inject a message into a court's bus.
#
# Usage:
#   court-send --project <p> --to <role> [--from <role>] [--reply-to <id>] "body"
#   court-send -p <p> --to <role> < body.md
set -e

PROJECT=""
FROM="human"
TO=""
REPLY_TO=""
BODY=""

while [ $# -gt 0 ]; do
  case "$1" in
    -p|--project) PROJECT="$2"; shift 2 ;;
    --from)       FROM="$2"; shift 2 ;;
    --to)         TO="$2"; shift 2 ;;
    --reply-to)   REPLY_TO="$2"; shift 2 ;;
    -h|--help)
      cat <<EOF
court-send — inject a message into a court's bus.

Usage:
  court-send -p <project> --to <role> [--from <role>] [--reply-to <id>] "body"
  court-send -p <project> --to <role> < body.md

Examples:
  court-send -p example --to foreman "ship the v0.2 changelog"
  court-send -p example --from frontend --to backend "is /api/users returning enum or string?"

Default --from is "human" (you, the operator).
EOF
      exit 0
      ;;
    *) BODY="$*"; break ;;
  esac
done

[ -z "$PROJECT" ] && { echo "[court-send] --project (-p) <project> required" >&2; exit 1; }
[ -z "$TO" ]      && { echo "[court-send] --to <role> required" >&2; exit 1; }

ROOT="${COURT_ROOT:-$HOME/.agent-court}"
PROJ_ROOT="$ROOT/projects/$PROJECT"

[ -d "$PROJ_ROOT" ] || { echo "[court-send] project '$PROJECT' not found ($PROJ_ROOT/)" >&2; exit 1; }

if [ -z "$BODY" ]; then
  if [ -t 0 ]; then
    echo "[court-send] no body and no stdin. Pass \"...\" or pipe via stdin." >&2
    exit 1
  fi
  BODY=$(cat)
fi

OUTBOX="$PROJ_ROOT/bus/$FROM/outbox"
if [ ! -d "$OUTBOX" ]; then
  # auto-create outbox for special senders (human, upstream)
  if [ "$FROM" = "human" ] || [ "$FROM" = "upstream" ]; then
    mkdir -p "$OUTBOX" "$PROJ_ROOT/bus/$FROM/inbox" "$PROJ_ROOT/bus/$FROM/inbox/.done"
  else
    echo "[court-send] from='$FROM' has no outbox ($OUTBOX). Add this role in court.yaml first." >&2
    exit 1
  fi
fi

ID=$(uuidgen | tr '[:upper:]' '[:lower:]' | tr -d '-' | head -c 8)
TS=$(date -Iseconds)
TS_EPOCH=$(date +%s)
FNAME="${TS_EPOCH}-${ID}-${FROM}-to-${TO}.md"
PATH_OUT="$OUTBOX/$FNAME"

{
  echo "---"
  echo "from: $FROM"
  echo "to: $TO"
  echo "ts: $TS"
  echo "id: $ID"
  [ -n "$REPLY_TO" ] && echo "in_reply_to: $REPLY_TO"
  echo "---"
  echo
  echo "$BODY"
} >"$PATH_OUT"

echo "[court-send:$PROJECT] wrote $PATH_OUT"
echo "  $FROM -> $TO (id=$ID)"
echo "  watcher will route to bus/$TO/inbox/"
