#!/usr/bin/env bash
# agent-court — migrate-to-court: roll a v0.2 (yamen) runtime back to
# v0.3 (court) schema.
#
# Performs the following transforms under $COURT_ROOT (default
# ~/.agent-court, falling back to ~/.agent-yamen if the new dir doesn't
# exist):
#
#   - rename ~/.agent-yamen        → ~/.agent-court
#   - per project under projects/<p>/:
#       yamen.yaml                 → court.yaml          (and key 'bangjiao:' → 'federation:',
#                                                          'tuiguan:' → 'judge:',
#                                                          'shenpi:' → 'approvals:')
#       bangjiao.yaml              → peers.yaml          (and 'yamen_id:' → 'court_id:')
#       lvli.yaml                  → policy.yaml
#       prompts/zongguan.md        → prompts/foreman.md
#       bus/zongguan/              → bus/foreman/
#       logs/panduo.jsonl          → logs/policy-log.jsonl
#       logs/bangjiao-errors.log   → logs/peer-errors.log
#       logs/shenpi-log.jsonl      → logs/approval-log.jsonl
#       (inside court.yaml) name/attach_window/prompt: zongguan → foreman
#                            session: yamen-X → court-X
#
# Idempotent: re-running on already-migrated dirs is a no-op.
# Pre-flight: interactive unless --yes; --dry-run shows what would change.
#
# Usage:
#   migrate-to-court                 # interactive
#   migrate-to-court --yes           # non-interactive
#   migrate-to-court --dry-run       # preview only

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PYTHON_BIN="$REPO_ROOT/mcp/court-mcp/.venv/bin/python3"
if [ ! -x "$PYTHON_BIN" ]; then
  PYTHON_BIN="python3"
fi

DRY=0
YES=0
NEW_NAME=""
PLAN_FILE=""
IF_NOT_EXISTS=0
for a in "$@"; do
  case "$a" in
    --dry-run) DRY=1;;
    --yes|-y)  YES=1;;
    --new=*) NEW_NAME="${a#--new=}" ;;
    --plan=*) PLAN_FILE="${a#--plan=}" ;;
    --if-not-exists) IF_NOT_EXISTS=1 ;;
    -h|--help)
      head -28 "$0" | sed 's/^# \?//'; exit 0;;
  esac
done

while [ $# -gt 0 ]; do
  case "$1" in
    --new) NEW_NAME="${2:-}"; shift 2 ;;
    --plan) PLAN_FILE="${2:-}"; shift 2 ;;
    --if-not-exists) IF_NOT_EXISTS=1; shift ;;
    --dry-run|--yes|-y|-h|--help) shift ;;
    *) shift ;;
  esac
done

OLD_ROOT="${HOME}/.agent-yamen"
NEW_ROOT="${COURT_ROOT:-$HOME/.agent-court}"

say() { echo "[migrate-to-court] $*"; }
do_or_say() { if [ $DRY -eq 1 ]; then say "DRY: $*"; else eval "$*"; fi; }

if [ -n "$NEW_NAME" ]; then
  [ -n "$PLAN_FILE" ] || { echo "[migrate-to-court] --plan is required with --new" >&2; exit 1; }
  ROOT="${COURT_ROOT:-$HOME/.agent-court}"
  if [ $DRY -eq 1 ]; then
    say "DRY: would create $ROOT/projects/$NEW_NAME from $PLAN_FILE"
    exit 0
  fi
  "$PYTHON_BIN" - "$NEW_NAME" "$PLAN_FILE" "$ROOT" "$IF_NOT_EXISTS" <<'PY'
from __future__ import annotations

import json
import os
import stat
import sys
from pathlib import Path

import yaml

name = sys.argv[1]
plan_file = Path(sys.argv[2])
root = Path(sys.argv[3])
if_not_exists = sys.argv[4] == "1"
plan = json.loads(plan_file.read_text())

proj = root / "projects" / name
if proj.exists():
    if if_not_exists:
        print(str(proj / "court.yaml"))
        raise SystemExit(0)
    raise SystemExit(f"[migrate-to-court] project already exists: {proj}")

(proj / "prompts").mkdir(parents=True)
(proj / "shared").mkdir(parents=True)
(proj / "logs").mkdir(parents=True)
(proj / "hooks").mkdir(parents=True)
for role in plan["roles"] + [{"name": "upstream"}]:
    (proj / "bus" / role["name"] / "inbox" / ".done").mkdir(parents=True, exist_ok=True)
    (proj / "bus" / role["name"] / "outbox").mkdir(parents=True, exist_ok=True)

session = plan.get("session") or f"agent-court-{name}"
court_yaml = {
    "project": name,
    "session": session,
    "attach_window": "foreman",
    "default_cli": "claude",
    "roles": [],
    "utility_windows": [
        {"name": "bus", "cmd": f"tail -f {proj / 'shared' / 'event.log'}"},
    ],
}

for role in plan["roles"]:
    prompt_name = f"{role['name']}.md"
    court_yaml["roles"].append({
        "name": role["name"],
        "prompt": prompt_name,
        "work_dir": role.get("work_dir", ""),
        "cli": role.get("cli", "claude"),
        "model": role.get("model", ""),
    })
    prompt = "\n".join([
        f"# {role['name']}",
        "",
        role.get("instructions", f"You are the {role['name']} role for project {name}."),
        "",
        "Critical git rules:",
        f"- Work only on branch prefix `{plan['branch_prefix']}`.",
        "- Never force push.",
        "- Never commit directly to `main`.",
        "- Before push, run `git pull --rebase`.",
        f"- Every commit message must end with `Issue: {plan['issue_ref']}`.",
        "",
        "Coordinate through the bus and keep replies concise.",
        "",
    ])
    (proj / "prompts" / prompt_name).write_text(prompt)

issue_ref = str(plan["issue_ref"])
repo_slug, issue_number = issue_ref.rsplit("#", 1)
hook_path = proj / "hooks" / "pre-push.sh"
hook_path.write_text(
    "\n".join([
        "#!/usr/bin/env bash",
        "set -euo pipefail",
        f"ISSUE_NUMBER={issue_number}",
        f"REPO_SLUG={repo_slug}",
        "",
        "while read -r local_ref local_sha remote_ref remote_sha; do",
        '  branch="${local_ref#refs/heads/}"',
        '  [ "$branch" = "main" ] && exit 1',
        '  [[ "$branch" == auto/issue-${ISSUE_NUMBER}/* ]] || exit 1',
        '  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then',
        '    git merge-base --is-ancestor "$remote_sha" "$local_sha" || exit 1',
        "  fi",
        '  range="$local_sha"',
        '  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then',
        '    range="$remote_sha..$local_sha"',
        "  fi",
        '  while read -r commit_sha; do',
        '    git log -1 --format=%B "$commit_sha" | grep -qE "^Issue: ${REPO_SLUG}#${ISSUE_NUMBER}$" || exit 1',
        '  done < <(git rev-list "$range")',
        "done",
        "",
    ])
)
hook_path.chmod(hook_path.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)

for role in plan["roles"]:
    work_dir = role.get("work_dir", "")
    if not work_dir:
        continue
    git_dir = Path(work_dir) / ".git"
    if not git_dir.is_dir():
        continue
    target = git_dir / "hooks"
    target.mkdir(parents=True, exist_ok=True)
    link = target / "pre-push"
    if link.exists() or link.is_symlink():
        link.unlink()
    os.symlink(hook_path, link)

(proj / "court.yaml").write_text(yaml.safe_dump(court_yaml, sort_keys=False))
(proj / "shared" / "event.log").touch()
print(str(proj / "court.yaml"))
PY
  exit 0
fi

# 1. Rename top-level dir if needed.
if [ -d "$OLD_ROOT" ] && [ ! -e "$NEW_ROOT" ]; then
  say "will mv $OLD_ROOT → $NEW_ROOT"
  if [ $YES -eq 0 ] && [ $DRY -eq 0 ]; then
    read -p "[migrate-to-court] proceed with whole-tree migration? (y/N) " ans
    [ "$ans" = "y" ] || { say "aborted"; exit 1; }
  fi
  do_or_say "mv \"$OLD_ROOT\" \"$NEW_ROOT\""
elif [ -d "$NEW_ROOT" ] && [ -d "$OLD_ROOT" ]; then
  say "warning: both $OLD_ROOT and $NEW_ROOT exist — leaving old root alone."
fi

ROOT="$NEW_ROOT"
[ -d "$ROOT/projects" ] || { say "nothing to migrate (no $ROOT/projects)"; exit 0; }

# 2. Per-project migrations.
for pdir in "$ROOT"/projects/*/; do
  proj="$(basename "$pdir")"
  say "--- project: $proj ---"

  # File renames (only if source exists AND target doesn't, for idempotency).
  if [ -f "$pdir/yamen.yaml" ] && [ ! -f "$pdir/court.yaml" ]; then
    do_or_say "mv \"$pdir/yamen.yaml\" \"$pdir/court.yaml\""
  fi
  if [ -f "$pdir/bangjiao.yaml" ] && [ ! -f "$pdir/peers.yaml" ]; then
    do_or_say "mv \"$pdir/bangjiao.yaml\" \"$pdir/peers.yaml\""
  fi
  if [ -f "$pdir/lvli.yaml" ] && [ ! -f "$pdir/policy.yaml" ]; then
    do_or_say "mv \"$pdir/lvli.yaml\" \"$pdir/policy.yaml\""
  fi
  if [ -f "$pdir/prompts/zongguan.md" ] && [ ! -f "$pdir/prompts/foreman.md" ]; then
    do_or_say "mv \"$pdir/prompts/zongguan.md\" \"$pdir/prompts/foreman.md\""
  fi
  if [ -d "$pdir/bus/zongguan" ] && [ ! -d "$pdir/bus/foreman" ]; then
    do_or_say "mv \"$pdir/bus/zongguan\" \"$pdir/bus/foreman\""
  fi
  # Log renames are best-effort (logs may not exist yet for a fresh project).
  if [ -f "$pdir/logs/panduo.jsonl" ] && [ ! -f "$pdir/logs/policy-log.jsonl" ]; then
    do_or_say "mv \"$pdir/logs/panduo.jsonl\" \"$pdir/logs/policy-log.jsonl\""
  fi
  if [ -f "$pdir/logs/bangjiao-errors.log" ] && [ ! -f "$pdir/logs/peer-errors.log" ]; then
    do_or_say "mv \"$pdir/logs/bangjiao-errors.log\" \"$pdir/logs/peer-errors.log\""
  fi
  if [ -f "$pdir/logs/shenpi-log.jsonl" ] && [ ! -f "$pdir/logs/approval-log.jsonl" ]; then
    do_or_say "mv \"$pdir/logs/shenpi-log.jsonl\" \"$pdir/logs/approval-log.jsonl\""
  fi

  # In-place YAML key + value swaps inside court.yaml / peers.yaml.
  for f in "$pdir/court.yaml" "$pdir/peers.yaml" "$pdir/policy.yaml"; do
    [ -f "$f" ] || continue
    if [ $DRY -eq 1 ]; then
      say "DRY: would sed $f"
    else
      sed -i '' '
        s|^bangjiao:|federation:|
        s|^  bangjiao:|  federation:|
        s|^    tuiguan:|    judge:|
        s|^  shenpi:|  approvals:|
        s|^yamen_id:|court_id:|
        s|^  yamen_id:|  court_id:|
        s|^    yamen_id:|    court_id:|
        s|name: zongguan$|name: foreman|
        s|attach_window: zongguan$|attach_window: foreman|
        s|prompt: zongguan\.md$|prompt: foreman.md|
        s|^session: yamen-|session: court-|
        s|^- zongguan$|- foreman|
        s|    - zongguan$|    - foreman|
      ' "$f" 2>/dev/null || true
    fi
  done
done

say "done."
say ""
say "next steps you may want to take:"
say "  1. re-register the MCP server under its old/canonical name:"
say "       claude mcp remove agent-yamen"
say "       claude mcp add -s user agent-court \\"
say "         \$HOME/Desktop/agent-court/mcp/court-mcp/.venv/bin/python \\"
say "         \$HOME/Desktop/agent-court/mcp/court-mcp/server.py"
say "  2. if you had a tmux session named 'yamen-<project>', rename it:"
say "       tmux rename-session -t yamen-<project> court-<project>"
say "  3. if you set YAMEN_ROOT in shell rc, switch back to COURT_ROOT."
