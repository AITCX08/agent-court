#!/usr/bin/env bash
# agent-court — court-approve (批准): list / approve / deny pending-approval
# messages awaiting human review. PR-5 entry point.
#
# Usage:
#   court-approve <project> list                 # show pending + expired
#   court-approve <project> approve <msg-id>     # release into peer inbox
#   court-approve <project> deny <msg-id>        # move into denied/
#   court-approve <project> cleanup              # auto-deny everything past timeout
#
# Audit trail lives at $COURT_ROOT/projects/<project>/logs/approval-log.jsonl
set -e

BIN="$(cd "$(dirname "$0")" && pwd)"
MCP_DIR="$(cd "$BIN/.." && pwd)/mcp/court-mcp"

VENV_PY="${COURT_VENV_PY:-$MCP_DIR/.venv/bin/python}"
if [ ! -x "$VENV_PY" ]; then
  echo "[court-approve] missing python venv at $VENV_PY" >&2
  echo "[court-approve] run: cd $MCP_DIR && uv venv .venv && uv pip install --python .venv/bin/python -e ." >&2
  exit 1
fi

exec "$VENV_PY" "$MCP_DIR/shenpi_cli.py" "$@"
