#!/usr/bin/env bash
# agent-court — generate this court's ed25519 keypair.
#
# Usage:
#   court-keygen              # generate if absent
#   court-keygen --force      # regenerate (invalidates trust with peers)
set -e

BIN="$(cd "$(dirname "$0")" && pwd)"
MCP_DIR="$(cd "$BIN/.." && pwd)/mcp/court-mcp"

VENV_PY="${COURT_VENV_PY:-$MCP_DIR/.venv/bin/python}"
if [ ! -x "$VENV_PY" ]; then
  echo "[court-keygen] missing python venv at $VENV_PY" >&2
  echo "[court-keygen] run: cd $MCP_DIR && uv venv .venv && uv pip install --python .venv/bin/python -e ." >&2
  exit 1
fi

exec "$VENV_PY" "$MCP_DIR/keygen.py" "$@"
