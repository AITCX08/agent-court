#!/usr/bin/env bash
# agent-court PR-8 -- start the jushi dynamic-memory daemon for a project.
#
# Idempotent: re-runs detect an existing pid and just print its status.
#
# Usage: jushi-up <project> [--interval N] [--no-summarize]
set -euo pipefail

PROJECT="${1:-}"
if [ -z "$PROJECT" ]; then
  echo "[jushi-up] usage: jushi-up <project> [--interval N] [--no-summarize]" >&2
  exit 2
fi
shift

BIN="$(cd "$(dirname "$0")" && pwd)"
MCP_DIR="$(cd "$BIN/.." && pwd)/mcp/court-mcp"
VENV_PY="${COURT_VENV_PY:-$MCP_DIR/.venv/bin/python}"
COURT_ROOT="${COURT_ROOT:-$HOME/.agent-court}"
LOGS="$COURT_ROOT/projects/$PROJECT/logs"
PID_FILE="$LOGS/jushi.pid"
LOG_FILE="$LOGS/jushi.log"

[ -x "$VENV_PY" ] || { echo "[jushi-up] no venv at $VENV_PY" >&2; exit 1; }
[ -f "$COURT_ROOT/projects/$PROJECT/court.yaml" ] || {
  echo "[jushi-up] missing $COURT_ROOT/projects/$PROJECT/court.yaml" >&2
  exit 1
}

mkdir -p "$LOGS"

if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
  echo "[jushi-up:$PROJECT] already running (pid $(cat "$PID_FILE")) -- log $LOG_FILE"
  exit 0
fi

# Detach into background. nohup + & is enough; the daemon owns SIGTERM/SIGINT
# handlers so jushi-down can stop it cleanly.
nohup env COURT_ROOT="$COURT_ROOT" "$VENV_PY" "$MCP_DIR/jushi_daemon.py" \
  --project "$PROJECT" "$@" \
  >>"$LOG_FILE" 2>&1 &

echo $! > "$PID_FILE"
sleep 0.5
if ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
  echo "[jushi-up:$PROJECT] daemon died on startup; tail of $LOG_FILE:" >&2
  tail -20 "$LOG_FILE" >&2 || true
  rm -f "$PID_FILE"
  exit 1
fi

echo "[jushi-up:$PROJECT] started (pid $(cat "$PID_FILE"), log $LOG_FILE)"
