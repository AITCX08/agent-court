#!/usr/bin/env bash
# agent-yamen — start a yamen.
# Spawns: watcher daemon + tmux session with N LLM CLI windows (one per role).
#
# Usage:
#   kaifu <project>          # start project at $YAMEN_ROOT/projects/<project>
#
# Env:
#   YAMEN_ROOT  — yamen home dir (default: ~/.agent-yamen)
set -e

PROJECT="${1:-}"
if [ -z "$PROJECT" ]; then
  echo "[kaifu] usage: kaifu <project>" >&2
  echo "available projects:" >&2
  ls -1 "${YAMEN_ROOT:-$HOME/.agent-yamen}/projects" 2>/dev/null | sed 's/^/  /' >&2
  exit 1
fi

ROOT="${YAMEN_ROOT:-$HOME/.agent-yamen}"
PROJ_ROOT="$ROOT/projects/$PROJECT"
CFG="$PROJ_ROOT/yamen.yaml"
BIN="$(cd "$(dirname "$0")" && pwd)"
LOGS="$PROJ_ROOT/logs"

[ -f "$CFG" ] || { echo "[kaifu] missing $CFG (project '$PROJECT' not found)" >&2; exit 1; }

SESSION=$(yq -r '.session' "$CFG")
ATTACH=$(yq -r '.attach_window' "$CFG")

if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "[kaifu:$PROJECT] session '$SESSION' already exists, attaching"
  tmux attach -t "$SESSION"
  exit 0
fi

mkdir -p "$LOGS"

WATCHER_PID_FILE="$LOGS/watcher.pid"
if [ -f "$WATCHER_PID_FILE" ] && kill -0 "$(cat "$WATCHER_PID_FILE")" 2>/dev/null; then
  echo "[kaifu:$PROJECT] watcher already running (pid $(cat "$WATCHER_PID_FILE"))"
else
  nohup "$BIN/qijuguan" "$PROJECT" >>"$LOGS/watcher.log" 2>&1 &
  echo $! >"$WATCHER_PID_FILE"
  echo "[kaifu:$PROJECT] watcher started (pid $(cat "$WATCHER_PID_FILE"), log $LOGS/watcher.log)"
fi

ROLES_COUNT=$(yq -r '.roles | length' "$CFG")
if [ "$ROLES_COUNT" -eq 0 ]; then
  echo "[kaifu:$PROJECT] no roles in yamen.yaml" >&2
  kill "$(cat "$WATCHER_PID_FILE")" 2>/dev/null || true
  exit 1
fi

FIRST_ROLE=$(yq -r '.roles[0].name' "$CFG")
tmux new-session -d -s "$SESSION" -n "$FIRST_ROLE"
tmux send-keys -t "$SESSION:$FIRST_ROLE" "$BIN/shengtang $PROJECT $FIRST_ROLE" Enter

for i in $(seq 1 $((ROLES_COUNT - 1))); do
  NAME=$(yq -r ".roles[$i].name" "$CFG")
  tmux new-window -t "$SESSION" -n "$NAME"
  tmux send-keys -t "$SESSION:$NAME" "$BIN/shengtang $PROJECT $NAME" Enter
done

UTIL_COUNT=$(yq -r '.utility_windows | length' "$CFG" 2>/dev/null || echo 0)
for i in $(seq 0 $((UTIL_COUNT - 1))); do
  NAME=$(yq -r ".utility_windows[$i].name" "$CFG")
  CMD=$(yq -r ".utility_windows[$i].cmd" "$CFG")
  tmux new-window -t "$SESSION" -n "$NAME"
  tmux send-keys -t "$SESSION:$NAME" "$CMD" Enter
done

tmux select-window -t "$SESSION:$ATTACH" 2>/dev/null || true

echo "[kaifu:$PROJECT] session '$SESSION' ready"
echo "  roles:   $(yq -r '.roles[].name' "$CFG" | tr '\n' ' ')"
echo "  utility: $(yq -r '.utility_windows[].name' "$CFG" 2>/dev/null | tr '\n' ' ')"
echo

exec tmux attach -t "$SESSION"
