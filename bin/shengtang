#!/usr/bin/env bash
# agent-yamen — launch a single role's LLM CLI for a yamen inside the current tmux window.
# Called by kaifu; can also be invoked manually for debugging:
#   shengtang <project> <role-name>
set -e

PROJECT="${1:-}"
ROLE="${2:-}"

if [ -z "$PROJECT" ] || [ -z "$ROLE" ]; then
  echo "[shengtang] usage: shengtang <project> <role-name>" >&2
  exit 1
fi

ROOT="${YAMEN_ROOT:-$HOME/.agent-yamen}"
PROJ_ROOT="$ROOT/projects/$PROJECT"
CFG="$PROJ_ROOT/yamen.yaml"

[ -f "$CFG" ] || { echo "[shengtang] missing $CFG" >&2; exit 1; }

# Resolve role config (prompt file, work dir, model, cli command)
PROMPT_FILE=$(yq -r ".roles[] | select(.name == \"$ROLE\") | .prompt" "$CFG")
WORK_DIR=$(yq -r ".roles[] | select(.name == \"$ROLE\") | .work_dir" "$CFG")
MODEL=$(yq -r ".roles[] | select(.name == \"$ROLE\") | .model" "$CFG")
ROLE_CLI=$(yq -r ".roles[] | select(.name == \"$ROLE\") | .cli" "$CFG")

if [ -z "$PROMPT_FILE" ] || [ "$PROMPT_FILE" = "null" ]; then
  echo "[shengtang] role '$ROLE' not found in project '$PROJECT' yamen.yaml" >&2
  exit 1
fi

PROMPT_PATH="$PROJ_ROOT/prompts/$PROMPT_FILE"
if [ ! -f "$PROMPT_PATH" ]; then
  echo "[shengtang] prompt file $PROMPT_PATH not found" >&2
  exit 1
fi

# Determine the LLM CLI to use: role-level override > project default > "claude"
if [ -z "$ROLE_CLI" ] || [ "$ROLE_CLI" = "null" ]; then
  ROLE_CLI=$(yq -r '.default_cli // "claude"' "$CFG")
fi

if [ -n "$WORK_DIR" ] && [ "$WORK_DIR" != "null" ] && [ -d "$WORK_DIR" ]; then
  cd "$WORK_DIR"
fi

# Build args. By convention each CLI is invoked with:
#   <cli> --append-system-prompt "$(cat <prompt>)" [--model <model>]
#
# If your CLI uses different flags, override with `cli` per role in yamen.yaml
# (e.g. set cli to a wrapper script that knows the right flags).
CLI_ARGS=( "--append-system-prompt" "$(cat "$PROMPT_PATH")" )
[ -n "$MODEL" ] && [ "$MODEL" != "null" ] && CLI_ARGS+=( "--model" "$MODEL" )

echo "[shengtang] project=$PROJECT role=$ROLE cli=$ROLE_CLI work_dir=$(pwd) prompt=$PROMPT_FILE"
exec "$ROLE_CLI" "${CLI_ARGS[@]}"
